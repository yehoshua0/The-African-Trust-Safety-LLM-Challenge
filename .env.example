# Copy this file to .env and fill in your keys.
# .env is gitignored — never commit real tokens.

# HuggingFace token — required for gated models (InkubaLM-0.4B, etc.)
# Get yours at: https://huggingface.co/settings/tokens
HF_TOKEN=hf_...

# OpenAI API key — optional, only needed for prompt optimization features in the webapp
OPENAI_API_KEY=sk-...
